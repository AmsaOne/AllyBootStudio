<Window x:Class="AllyBootStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ally Boot Studio"
        Width="1080" Height="640"
        MinWidth="900" MinHeight="540"
        Background="{StaticResource Bg}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.Resources>
        <Style x:Key="Heading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="Subtle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,16">
            <TextBlock Text="Ally Boot Studio" Style="{StaticResource Heading}"/>
            <TextBlock Style="{StaticResource Subtle}">
                <Run Text="Replace your Armoury Crate SE boot animation with a custom MP4. "/>
                <Run Text="ACSE root: " Foreground="{StaticResource TextDim}"/>
                <Run Text="{Binding DetectedRoot}" Foreground="{StaticResource Text}"/>
            </TextBlock>
        </StackPanel>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: slot list -->
            <Border Background="{StaticResource Panel}" CornerRadius="10" Padding="12">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Animation slots" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button  Grid.Column="1" Content="Pick folder" Command="{Binding PickRootCommand}"   Margin="0,0,6,0"/>
                        <Button  Grid.Column="2" Content="Refresh"    Command="{Binding RefreshSlotsCommand}"/>
                    </Grid>
                    <ListBox Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding Slots}"
                             SelectedItem="{Binding SelectedSlot}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="{StaticResource TextDim}" FontSize="11">
                                            <Run Text="ID "/>
                                            <Run Text="{Binding Id}"/>
                                            <Run Text="  •  "/>
                                            <Run Text="{Binding CurrentSizeBytes, StringFormat={}{0:N0} bytes}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="•"
                                               FontSize="22"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Good}"
                                               ToolTip="Backup exists">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasBackup}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right: source + actions -->
            <Border Grid.Column="1" Background="{StaticResource Panel}" CornerRadius="10" Padding="20" Margin="14,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Source video" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Style="{StaticResource Subtle}"
                                   Text="Drag-and-drop a video onto this window, or click Browse. We'll validate the codec and offer to transcode."/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{StaticResource PanelHi}"
                            CornerRadius="8"
                            BorderBrush="#2A3142"
                            BorderThickness="1"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="{Binding SourceMp4, FallbackValue='No file selected'}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding ValidationMessage}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Browse..."   Command="{Binding BrowseSourceCommand}" Margin="0,0,8,0"/>
                                <Button Content="Transcode"   Command="{Binding TranscodeCommand}"   Margin="0,0,8,0"/>
                                <Button Content="Cancel"      Command="{Binding CancelCommand}"
                                        ToolTip="Cancel the running transcode"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Apply to selected slot"  Style="{StaticResource AccentButton}" Command="{Binding ApplyCommand}" Margin="0,0,8,0"/>
                        <Button Content="Restore original"        Command="{Binding RestoreCommand}"   Margin="0,0,8,0"/>
                        <Button Content="Open slot folder"        Command="{Binding OpenSlotFolderCommand}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3"
                               Margin="0,16,0,0"
                               TextWrapping="Wrap"
                               Style="{StaticResource Subtle}"
                               Text="Tip: select the matching animation in Armoury Crate ›  Settings  ›  General  ›  Personalization. Restart Armoury Crate after Apply."/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="0,14,0,0" Background="{StaticResource Panel}" CornerRadius="8" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Foreground="{StaticResource TextDim}" FontSize="11"
                           Text="{Binding IsBusy, StringFormat='busy: {0}'}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
